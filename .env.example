# Server port (default: 8082)
PORT=8082

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Engine pool size — increase for more concurrent games (default: 2)
ENGINE_POOL_SIZE=2

# Federation / Network discovery (default: on)
# Set to "off" to disable all federation and peer discovery.
# Local multiplayer (same server) still works when off.
TESS_DISCOVERY=on

# Server name shown to federated peers (default: Tess)
TESS_SERVER_NAME=Tess

# Custom discovery topic — set a shared secret to create a private
# discovery group (only instances with the same topic find each other).
# Leave unset for public discovery (default).
# TESS_DISCOVERY_TOPIC=my-friends-group-2024
